# MCP-Gateway: Alle 4 MCP-Server als HTTP-Endpoints (mcpo-Proxy)
#
# Python-basiert (mcpo, dbt-mcp, airflow-mcp) + Node.js (postgres-mcp, metabase-mcp)
# API-Docs: http://localhost:8200/docs

FROM python:3.12-slim

# Node.js 20 LTS installieren (fuer postgres-mcp und metabase-mcp)
RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Python MCP-Server
RUN pip install --no-cache-dir \
    mcpo \
    mcp-server-apache-airflow \
    dbt-mcp \
    dbt-postgres

# Node.js MCP-Server vorab cachen (beschleunigt den ersten Start)
RUN npx -y @modelcontextprotocol/server-postgres --version 2>/dev/null || true

CMD ["mcpo", "--host", "0.0.0.0", "--port", "8200", "--config", "/mcp-config.json"]

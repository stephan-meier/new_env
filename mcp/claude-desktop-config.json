{
  "_anleitung": [
    "Template fuer Claude Desktop MCP-Konfiguration.",
    "Datei: ~/Library/Application Support/Claude/claude_desktop_config.json  (macOS)",
    "       ~/.claude/claude_desktop_config.json  (Linux ?)",
    "       %APPDATA%\\Claude\\claude_desktop_config.json  (Windows)",
    "",
    "WICHTIG: /ABSOLUTER/PFAD/ZU/new_env durch den tatsaechlichen Pfad ersetzen!",
    "         Die Demo-Umgebung muss laufen (docker compose up -d).",
    "",
    "Voraussetzungen:",
    "  PostgreSQL MCP: npm / npx verfuegbar",
    "  dbt MCP:        uv verfuegbar (pip install uv) + Python >= 3.12",
    "  Metabase MCP:   npx verfuegbar + Metabase-Overlay aktiv (docker-compose.bi.yml)",
    "  Airflow MCP:    Kein reifer Airflow-3-MCP verfuegbar (Stand 2026). Airflow ueber Web-UI verwalten."
  ],

  "mcpServers": {

    "postgres-demo": {
      "_comment": "PostgreSQL MCP (offiziell, Anthropic): Schema-Inspektion, read-only SQL",
      "_repo": "https://github.com/modelcontextprotocol/servers/tree/main/src/postgres",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://mcp_reader:mcp_readonly@localhost:5432/demo"
      ]
    },

    "airflow-meta": {
      "_comment": "Airflow Metadaten-DB: DAG Runs, Task Instances, Logs, Variables, Connections",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://mcp_reader:mcp_readonly@localhost:5432/airflow"
      ]
    },

    "dbt-demo": {
      "_comment": "dbt MCP (offiziell, dbt Labs): run/test/compile, Lineage, YAML-Codegen",
      "_repo": "https://github.com/dbt-labs/dbt-mcp",
      "command": "uvx",
      "args": ["dbt-mcp"],
      "env": {
        "DBT_PROJECT_DIR": "/ABSOLUTER/PFAD/ZU/new_env/dbt_project",
        "DBT_PROFILES_DIR": "/ABSOLUTER/PFAD/ZU/new_env/dbt_project",
        "DBT_MCP_ENABLE_DBT_CLI": "false",
        "DBT_MCP_ENABLE_DBT_CODEGEN": "true",
        "DBT_PATH": "/opt/anaconda3/envs/dbt/bin/dbt",
        "POSTGRES_HOST": "localhost"
      }
    },

    "metabase-demo": {
      "_comment": "Metabase MCP (Community): Dashboards, Questions ausfuehren, Schema erkunden",
      "_repo": "https://github.com/CognitionAI/metabase-mcp-server",
      "_voraussetzung": "Metabase-Overlay muss laufen: docker-compose.bi.yml",
      "command": "npx",
      "args": ["-y", "@cognitionai/metabase-mcp-server"],
      "env": {
        "METABASE_URL": "http://localhost:3000",
        "METABASE_API_KEY": "METABASE_API_KEY_HIER_EINTRAGEN"
      }
    }

  }
}

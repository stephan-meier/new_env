# =============================================================================
# Demo Environment - Konfiguration
# =============================================================================
# Diese Datei als .env kopieren:   cp .env.example .env
# Dann die Keys generieren (siehe unten) und eintragen.
# =============================================================================

# PostgreSQL
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=demo_pass
POSTGRES_DB=demo

# -----------------------------------------------------------------------------
# Airflow - Fernet Key (Verschluesselung von Connections/Variables)
# -----------------------------------------------------------------------------
# Neuen Key generieren:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Falls cryptography nicht installiert ist:
#   pip install cryptography
#
# Oder alternativ mit openssl:
#   openssl rand -base64 32
#
AIRFLOW__CORE__FERNET_KEY=<HIER_FERNET_KEY_EINTRAGEN>

# -----------------------------------------------------------------------------
# Airflow 3 - Shared Secrets (muessen auf ALLEN Containern identisch sein!)
# -----------------------------------------------------------------------------
# Diese Keys sichern die API- und JWT-Kommunikation zwischen Scheduler,
# API-Server, DAG-Processor und Worker. Bei Airflow 2.x war das nicht noetig.
#
# Generieren z.B. mit:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
AIRFLOW__API__SECRET_KEY=<HIER_API_SECRET_EINTRAGEN>
AIRFLOW__API_AUTH__JWT_SECRET=<HIER_JWT_SECRET_EINTRAGEN>
